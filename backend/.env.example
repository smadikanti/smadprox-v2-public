# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Speech-to-Text ──────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-key

# ─── Text-to-Speech ──────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=default-voice-id

# ─── LLM: Coaching (fast path) ───────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ─── LLM: Script Generation (high-reasoning) ─────────────
# Uses same ANTHROPIC_API_KEY, model override in script_generator.py
# CLAUDE_OPUS_MODEL=claude-opus-4-6

# ─── LLM: Fast classification ────────────────────────────
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Twilio (optional — for phone-based sessions) ────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Auth (optional — for SaaS mode) ─────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_ISSUER_URL=

# ─── Billing (optional) ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
PUBLIC_URL=https://api.nohuman.live
ALLOWED_ORIGINS=*
